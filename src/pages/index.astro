---
import { ClientRouter, fade } from 'astro:transitions';
import Header from '../components/Header.astro';
import '../styles/global.css';
---

<html lang="uz">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" href="/favicon.ico" sizes="32x32" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <title>Shavkatov Fayzulloh — SEO, AEO va GEO bo'yicha maslahatchi</title>
  <meta name="description" content="Bizneslarni Google va AI'da topga chiqaraman. SEO, AEO va GEO bo'yicha amaliy maslahat va xizmatlar." />
  <meta name="author" content="Shavkatov Fayzulloh" />
  <link rel="canonical" href="https://shavkatov.io/" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://shavkatov.io/" />
  <meta property="og:title" content="Shavkatov Fayzulloh — SEO, AEO va GEO bo'yicha maslahatchi" />
  <meta property="og:description" content="Bizneslarni Google va AI'da topga chiqaraman." />
  <meta property="og:image" content="https://shavkatov.io/og-image.jpg" />
  <meta property="og:locale" content="uz_UZ" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content="Shavkatov Fayzulloh — SEO, AEO va GEO bo'yicha maslahatchi" />
  <meta name="twitter:description" content="Bizneslarni Google va AI'da topga chiqaraman." />
  <meta name="twitter:image" content="https://shavkatov.io/og-image.jpg" />

  <meta name="theme-color" content="#000000" />
  <meta name="color-scheme" content="dark" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;500;600;700&family=Poppins:wght@300;400;500;600&display=swap" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;500;600;700&family=Poppins:wght@300;400;500;600&display=swap" media="print" onload="this.media='all'" />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;500;600;700&family=Poppins:wght@300;400;500;600&display=swap" /></noscript>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Shavkatov Fayzulloh",
      "additionalName": "Furqat o'g'li",
      "jobTitle": "SEO, AEO & GEO Consultant",
      "description": "SEO, AEO and GEO consultant helping SMBs grow through search. Founder of Darslinker.uz. 3+ years of project management experience in IT and marketing.",
      "url": "https://shavkatov.io",
      "image": "https://shavkatov.io/og-image.jpg",
      "knowsAbout": [
        "Search Engine Optimization",
        "Answer Engine Optimization",
        "Generative Engine Optimization",
        "Project Management",
        "Digital Marketing"
      ],
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Tashkent",
        "addressCountry": "UZ"
      },
      "worksFor": {
        "@type": "Organization",
        "name": "Darslinker",
        "url": "https://darslinker.uz"
      },
      "sameAs": [
        "https://t.me/shavkatov_ff",
        "https://instagram.com/shavkatov.io"
      ]
    }
  </script>
  <!-- Microsoft Clarity (deferred until after load) -->
  <script type="text/javascript">
    (function () {
      function loadClarity() {
        (function(c,l,a,r,i,t,y){
          c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
          t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
          y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
        })(window, document, "clarity", "script", "vf4tq5adhl");
      }
      function schedule() {
        if ('requestIdleCallback' in window) {
          window.requestIdleCallback(loadClarity, { timeout: 3000 });
        } else {
          setTimeout(loadClarity, 1500);
        }
      }
      if (document.readyState === 'complete') schedule();
      else window.addEventListener('load', schedule, { once: true });
    })();
  </script>
  <ClientRouter />
</head>
<body class="hero-page">
  <canvas id="splashCanvas"></canvas>
  <Header />
  <section class="hero" transition:animate={fade({ duration: '0.4s' })}>
    <div class="hero-content container">
      <p class="hero-tagline" id="heroTagline"><span class="tag-line1" id="taglineLine1">Bizneslarni Google va AI'da</span> <span class="tag-line2" id="taglineLine2">top 10-talikka chiqaraman</span></p>
      <h1 class="hero-name" id="heroName">Shavkatov Fayzulloh</h1>
      <div class="hero-links" id="heroLinks">
        <a href="/services" id="servicesLink">Xizmatlar</a>
        <a href="/blog">Blog</a>
        <a href="/about" id="aboutLink">Haqida</a>
      </div>
    </div>
  </section>
</body>
</html>

<script>
  let isFirstLoad = true;

  function setup() {
    // Faqat bosh sahifada ishlaydi
    const heroName = document.getElementById('heroName');
    if (!heroName) return;

    const canvas = document.getElementById('splashCanvas') as HTMLCanvasElement;
    const hasFinePointer = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (canvas && hasFinePointer && !prefersReducedMotion) {
      const idleInit = () => {
        import('../scripts/splash-cursor.js').then(({ initSplashCursor }) => {
          initSplashCursor(canvas);
        });
      };
      if ('requestIdleCallback' in window) {
        (window as any).requestIdleCallback(idleInit, { timeout: 2000 });
      } else {
        setTimeout(idleInit, 500);
      }
    } else if (canvas) {
      canvas.style.display = 'none';
    }

    const heroLinks = document.getElementById('heroLinks');
    const heroTagline = document.getElementById('heroTagline');
    const headerEl = document.querySelector('header');

    if (isFirstLoad) {
      // Saytga yangi kirilganda: animatsiya bilan
      isFirstLoad = false;

      // Darhol boshlanadi — hammasi birga
      heroTagline?.classList.add('visible');
      heroName.classList.add('visible');
      heroLinks?.classList.add('visible');
      headerEl?.style.setProperty('opacity', '1');
      headerEl?.style.setProperty('filter', 'blur(0px)');
    } else {
      // Ichki sahifadan qaytganda: hero elementlarini darhol ko'rsatish (transition o'chiriladi)
      if (heroTagline) heroTagline.style.cssText = 'opacity:1;filter:none;transition:none';
      heroName.style.cssText = 'opacity:1;filter:none;transition:none';
      heroLinks!.style.cssText = 'opacity:1;filter:none;transition:none';
      headerEl!.style.setProperty('opacity', '1');
      headerEl!.style.setProperty('filter', 'none');
      headerEl!.style.setProperty('transition', 'none');
    }

    // Til o'zgarganda nav linklari almashadi
    const aboutLink = document.getElementById('aboutLink');
    const servicesLink = document.getElementById('servicesLink');
    const updateNavText = (lang: string) => {
      if (aboutLink) aboutLink.textContent = lang === 'en' ? 'About' : 'Haqida';
      if (servicesLink) servicesLink.textContent = lang === 'en' ? 'Services' : 'Xizmatlar';
      const line1 = document.getElementById('taglineLine1');
      const line2 = document.getElementById('taglineLine2');
      if (line1 && line2) {
        line1.textContent = lang === 'en' ? 'I get businesses into top 10' : 'Bizneslarni Google va AI\'da';
        line2.textContent = lang === 'en' ? 'on Google and AI' : 'top 10-talikka chiqaraman';
      }
    };
    updateNavText(localStorage.getItem('lang') || 'uz');
    document.addEventListener('langchange', (e: any) => updateNavText(e.detail));
  }

  // astro:page-load har safar ishlaydi — ham birinchi yuklashda, ham View Transition keyin
  document.addEventListener('astro:page-load', setup);
</script>

<style>
  #splashCanvas {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
  }

  .hero-page {
    margin: 0;
    overflow: hidden;
    position: fixed;
    inset: 0;
  }

  .hero {
    display: flex;
    align-items: center;
    justify-content: center;
    position: absolute;
    top: 60px;
    left: 0;
    right: 0;
    bottom: 0;
    padding-bottom: 30vh;
  }

  .hero-content {
    text-align: center;
    position: relative;
    z-index: 2;
  }

  .hero-tagline {
    font-family: 'Poppins', sans-serif;
    font-size: clamp(0.95rem, 1.6vw, 1.1rem);
    font-weight: 300;
    color: #b3b3b3;
    margin: 0 auto 2.5rem;
    line-height: 1.5;
    letter-spacing: 0.01em;
    white-space: nowrap;
    opacity: 0;
    filter: blur(8px);
    transition: opacity 0.25s ease-out, filter 0.25s ease-out;
  }

  .hero-tagline.visible {
    opacity: 1;
    filter: blur(0px);
  }

  @media (max-width: 640px) {
    .hero-tagline {
      white-space: normal;
    }

    .hero-tagline .tag-line2 {
      display: block;
    }
  }

  .hero-name {
    font-family: 'Caveat', cursive;
    font-size: clamp(2.5rem, 8vw, 4.5rem);
    font-weight: 400;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
    line-height: 1.1;
    white-space: nowrap;
    color: #b3b3b3;
    opacity: 0;
    filter: blur(10px);
    transition: opacity 0.25s ease-out, filter 0.25s ease-out;
  }

  .hero-name.visible {
    opacity: 1;
    filter: blur(0px);
  }

  .hero-links {
    display: flex;
    gap: 2rem;
    justify-content: center;
    opacity: 0;
    filter: blur(5px);
    transition: opacity 0.25s ease-out, filter 0.25s ease-out;
  }

  .hero-links.visible {
    opacity: 1;
    filter: blur(0px);
  }

  .hero-links a {
    color: #b3b3b3;
    font-size: 0.95rem;
    font-family: 'Poppins', sans-serif;
    transition: color 0.2s ease;
  }

  .hero-links a:hover {
    color: var(--color-text);
  }

  :global(header) {
    opacity: 0;
    filter: blur(5px);
    transition: opacity 0.25s ease-out, filter 0.25s ease-out;
  }

</style>
