---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTA from '../../components/CTA.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Reading time (200 wpm average)
const wordCount = post.body?.split(/\s+/).filter(Boolean).length ?? 0;
const readingMinutes = Math.max(1, Math.round(wordCount / 200));

const formatDate = (d: Date, lang: 'uz' | 'en') => {
  if (lang === 'en') {
    return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
  }
  return d.toLocaleDateString('uz-UZ', { year: 'numeric', month: 'long', day: 'numeric' });
};

const publishedUz = formatDate(post.data.date, 'uz');
const publishedEn = formatDate(post.data.date, 'en');
const updated = post.data.lastUpdated;
const updatedUz = updated ? formatDate(updated, 'uz') : null;
const updatedEn = updated ? formatDate(updated, 'en') : null;
---

<BaseLayout
  title={`${post.data.title} - Shavkatov`}
  description={post.data.description}
  article={true}
>
  <Fragment slot="head">
    <meta property="article:published_time" content={post.data.date.toISOString()} />
    {updated && <meta property="article:modified_time" content={updated.toISOString()} />}
    <meta property="article:author" content="Shavkatov Fayzulloh" />
    {post.data.faq && post.data.faq.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": post.data.faq.map((item) => ({
          "@type": "Question",
          "name": item.question,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": item.answer,
          },
        })),
      })} />
    )}
  </Fragment>
  <article class="blog-post" transition:animate="fade">
    <header>
      <h1 id="postTitle" data-uz={post.data.title} data-en={post.data.title_en || post.data.title}>{post.data.title}</h1>
      {(post.data.description || post.data.description_en) && (
        <h4 class="description" id="postDesc" data-uz={post.data.description} data-en={post.data.description_en || post.data.description}>{post.data.description}</h4>
      )}
      <div class="meta">
        <time
          datetime={post.data.date.toISOString()}
          id="publishedDate"
          data-uz={publishedUz}
          data-en={publishedEn}
        >{publishedUz}</time>
        {updated && (
          <>
            <span class="meta-sep">·</span>
            <span
              id="updatedDate"
              data-uz={`Yangilangan: ${updatedUz}`}
              data-en={`Updated: ${updatedEn}`}
            >Yangilangan: {updatedUz}</span>
          </>
        )}
        <span class="meta-sep">·</span>
        <span
          id="readingTime"
          data-uz={`${readingMinutes} daqiqa o'qish`}
          data-en={`${readingMinutes} min read`}
        >{readingMinutes} daqiqa o'qish</span>
      </div>
    </header>

    {(post.data.tldr || post.data.tldr_en) && (
      <aside class="tldr">
        <strong
          id="tldrLabel"
          data-uz="Qisqa javob:"
          data-en="TL;DR:"
        >Qisqa javob:</strong>
        <p
          id="tldrBody"
          data-uz={post.data.tldr || ''}
          data-en={post.data.tldr_en || post.data.tldr || ''}
        >{post.data.tldr}</p>
      </aside>
    )}

    <div class="content">
      <Content />
    </div>

    {post.data.faq && post.data.faq.length > 0 && (
      <section class="faq">
        <h2 id="faqTitle" data-uz="Tez-tez beriladigan savollar" data-en="Frequently asked questions">Tez-tez beriladigan savollar</h2>
        {post.data.faq.map((item) => (
          <details class="faq-item" name="post-faq">
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </section>
    )}

    <CTA />

    <section class="author-bio">
      <p>
        <strong>Shavkatov Fayzulloh</strong> — Bizneslarni Google va AI qidiruv tizimlarida topga chiqaraman.
      </p>
    </section>

    <footer>
      <a href="/blog" id="backLink">&larr; Ortga</a>
    </footer>
  </article>
</BaseLayout>

<script>
  const setLang = (lang: string) => {
    document.querySelectorAll('[data-uz]').forEach((el) => {
      const e = el as HTMLElement;
      if (e.dataset.en !== undefined) {
        e.textContent = lang === 'en' ? (e.dataset.en || '') : (e.dataset.uz || '');
      }
    });
    const backLink = document.getElementById('backLink');
    if (backLink) backLink.innerHTML = lang === 'en' ? '&larr; Back' : '&larr; Ortga';
    const contentUz = document.querySelector('.content-uz') as HTMLElement;
    const contentEn = document.querySelector('.content-en') as HTMLElement;
    if (contentUz) contentUz.style.display = lang === 'en' ? 'none' : 'block';
    if (contentEn) contentEn.style.display = lang === 'en' ? 'block' : 'none';
  };
  setLang(localStorage.getItem('lang') || 'uz');
  document.addEventListener('langchange', (e: any) => setLang(e.detail));
</script>

<style>
  .blog-post {
    padding: 0.5rem 0;
  }

  header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(118, 118, 118, 0.5);
  }

  header h1 {
    margin: 0;
    color: var(--color-text);
    font-size: clamp(1.4rem, 4vw, 2rem);
    line-height: 1.3;
  }

  .description {
    color: var(--color-secondary);
    font-size: 1.1rem;
    margin: 0.75rem 0 0;
    font-weight: 400;
  }

  .meta {
    margin-top: 0.85rem;
    font-size: 0.85rem;
    color: var(--color-secondary);
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-items: center;
  }

  .meta-sep {
    opacity: 0.6;
  }

  .tldr {
    margin: 0 0 2rem;
    padding: 1rem 1.25rem;
    border-left: 3px solid var(--color-text);
    background: rgba(255, 255, 255, 0.03);
    border-radius: 0 8px 8px 0;
  }

  .tldr strong {
    display: block;
    color: var(--color-text);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.4rem;
  }

  .tldr p {
    color: var(--color-text);
    line-height: 1.65;
    margin: 0;
  }

  .content {
    line-height: 1.8;
    color: #b3b3b3;
  }

  .content :global(h2) {
    margin-top: 2.5rem;
    color: var(--color-text);
  }

  .content :global(h3) {
    margin-top: 1.5rem;
    color: var(--color-text);
  }

  .content :global(a) {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .content :global(img) {
    border-radius: 8px;
    margin: 1.5rem 0;
  }

  /* Table styles — applies to all markdown tables in posts */
  .content :global(.table-wrap) {
    margin: 1.75rem 0;
    overflow-x: auto;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.02);
  }

  .content :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.93rem;
    margin: 0;
  }

  .content :global(thead) {
    background: rgba(255, 255, 255, 0.05);
  }

  .content :global(th) {
    padding: 0.85rem 1.1rem;
    text-align: left;
    color: var(--color-text);
    font-weight: 500;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .content :global(td) {
    padding: 0.85rem 1.1rem;
    color: var(--color-secondary);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    line-height: 1.55;
    vertical-align: top;
  }

  .content :global(tbody tr:last-child td) {
    border-bottom: none;
  }

  .content :global(tbody tr:hover td) {
    background: rgba(255, 255, 255, 0.02);
  }

  .content :global(td:first-child) {
    color: var(--color-text);
    font-weight: 500;
    white-space: nowrap;
  }

  /* Fallback for tables without wrapper */
  .content :global(table:not(.table-wrap > table)) {
    margin: 1.75rem 0;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.02);
  }

  @media (max-width: 640px) {
    .content :global(th),
    .content :global(td) {
      padding: 0.7rem 0.8rem;
      font-size: 0.85rem;
    }

    .content :global(td:first-child) {
      white-space: normal;
    }
  }

  .faq {
    margin-top: 3rem;
  }

  .faq h2 {
    color: var(--color-text);
    margin-bottom: 1.25rem;
  }

  .faq-item {
    margin-bottom: 0.75rem;
    padding: 1rem 1.25rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.02);
  }

  .faq-item summary {
    cursor: pointer;
    color: var(--color-text);
    font-weight: 500;
    list-style: none;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary::after {
    content: '+';
    float: right;
    color: var(--color-secondary);
    transition: transform 0.2s ease;
  }

  .faq-item[open] summary::after {
    content: '−';
  }

  .faq-item p {
    margin-top: 0.75rem;
    color: var(--color-secondary);
    line-height: 1.7;
  }

  .author-bio {
    margin-top: 2rem;
    padding: 1rem 0;
    border-top: 1px solid rgba(118, 118, 118, 0.3);
    color: var(--color-secondary);
    font-size: 0.9rem;
  }

  .author-bio p {
    margin: 0;
    line-height: 1.6;
  }

  .author-bio strong {
    color: var(--color-text);
  }

  .author-bio a {
    color: var(--color-secondary);
    text-decoration: underline;
    text-underline-offset: 3px;
    white-space: nowrap;
  }

  .author-bio a:hover {
    color: var(--color-text);
  }

  footer {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(118, 118, 118, 0.3);
  }

  footer a {
    color: var(--color-secondary);
  }

  footer a:hover {
    color: var(--color-text);
  }
</style>
